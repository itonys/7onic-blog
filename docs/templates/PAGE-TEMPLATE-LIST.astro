---
// PAGE-TEMPLATE-LIST.astro
// Copy this file to src/pages/[your-page].astro for listing pages with header.
// Used for: category-style pages, archive pages, custom listing pages.
// (Note: /series and /category are already handled by dynamic routes in src/pages/)
//
// Rules:
// - Add page-top class to the .page-header div (NOT to main)
// - Never write padding-top directly — use page-top (defined in global.css)
// - Always include <Sidebar /> inside page-wrapper
// - Always include <Footer /> at the bottom
// - Add mobile @media (max-width: 768px) block even if currently empty

import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_TITLE } from '../consts';

// TODO: update title and description
const title = 'Page Title';
const description = 'Page description (120–160 chars for SEO).';

// TODO: replace with real data
const items: { href: string; title: string; date?: Date; description?: string }[] = [];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
  </head>
  <body>
    <Header />
    <div class="page-wrapper">
      <main class="main-content">

        <div class="page-header page-top">
          <a href="/" class="back-link">← All Posts</a>
          <h1 class="page-title">{title}</h1>
          {description && <p class="page-desc">{description}</p>}
        </div>

        {items.length === 0 ? (
          <p class="empty">No items yet.</p>
        ) : (
          <ul class="item-list">
            {items.map((item) => (
              <li class="item">
                <a href={item.href} class="item-link">
                  <h2 class="item-title">{item.title}</h2>
                  {item.description && <p class="item-desc">{item.description}</p>}
                </a>
              </li>
            ))}
          </ul>
        )}

      </main>
      <Sidebar />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding-bottom: 4rem;
  }

  .page-header {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .page-title {
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0 0 0.625rem;
  }

  .page-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .empty {
    padding-top: 3rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .item-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .item {
    border-bottom: 1px solid var(--color-border);
  }

  .item-link {
    display: block;
    padding: 1.25rem 0;
    text-decoration: none;
  }

  .item-link:hover .item-title {
    color: #7c3aed;
  }

  .item-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.3rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .item-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .page-wrapper {
      flex-direction: column;
      gap: 0;
      padding: 0 1rem;
    }
    /* Add mobile-specific overrides below */
  }
</style>
