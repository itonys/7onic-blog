---
import { SITE_TITLE, DOCS_URL } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="copyright">
      © {year} {SITE_TITLE}. Built with
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
    </p>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={DOCS_URL} target="_blank" rel="noopener noreferrer">Docs</a>
      <a href="https://github.com/itonys/7onic" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .copyright {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .copyright a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .copyright a:hover {
    color: var(--color-text);
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .footer-nav a {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--color-text);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
