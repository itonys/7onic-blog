---
import { DOCS_URL } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Logo -->
    <a href="/" class="footer-logo" aria-label="7onic Blog">
      <svg viewBox="0 0 18 27" width="16" height="24" aria-hidden="true">
        <defs>
          <clipPath id="fc"><rect width="18" height="27"/></clipPath>
          <mask id="fm" maskUnits="userSpaceOnUse" x="3" y="0" width="15" height="27" style="mask-type:alpha">
            <path d="M17.0458 5.30189C17.6547 3.62877 16.7921 1.77877 15.1189 1.1698C13.4458 0.560834 11.5958 1.4235 10.9868 3.09663L4.18728 21.7783C3.57831 23.4514 4.44098 25.3014 6.11411 25.9104C7.78723 26.5193 9.63723 25.6567 10.2462 23.9835L17.0458 5.30189Z" fill="white"/>
          </mask>
        </defs>
        <g clip-path="url(#fc)">
          <path class="footer-mono-h" d="M3.22388 0.873132C1.44338 0.873132 0 2.31651 0 4.09701C0 5.87751 1.44338 7.32089 3.22388 7.32089L13.7015 7.32089C15.482 7.32089 16.9254 5.87751 16.9254 4.09701C16.9254 2.31651 15.482 0.873132 13.7015 0.873132L3.22388 0.873132Z"/>
          <path class="footer-mono-d" d="M16.7417 5.1912C17.3507 3.51808 16.5561 1.69286 14.9669 1.11446C13.3778 0.536056 11.5959 1.4235 10.9869 3.09663L4.18734 21.7783C3.57838 23.4514 4.37297 25.2766 5.96211 25.855C7.55125 26.4334 9.33318 25.546 9.94214 23.8729L16.7417 5.1912Z"/>
          <g mask="url(#fm)">
            <path class="footer-mono-i" d="M3.22388 0.873132C1.44338 0.873132 0 2.31651 0 4.09701C0 5.87751 1.44338 7.32089 3.22388 7.32089L13.7015 7.32089C15.482 7.32089 16.9254 5.87751 16.9254 4.09701C16.9254 2.31651 15.482 0.873132 13.7015 0.873132L3.22388 0.873132Z"/>
          </g>
        </g>
      </svg>
    </a>

    <!-- Nav links -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={DOCS_URL} target="_blank" rel="noopener noreferrer">Design System</a>
      <span class="footer-dot" aria-hidden="true">·</span>
      <a href="https://github.com/itonys/7onic" target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-dot" aria-hidden="true">·</span>
      <a href="https://x.com/7onicHQ" target="_blank" rel="noopener noreferrer">
        <svg width="13" height="13" viewBox="0 0 1200 1227" fill="currentColor" aria-label="X">
          <path d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"/>
        </svg>
      </a>
      <span class="footer-dot" aria-hidden="true">·</span>
      <a href="/rss.xml">RSS</a>
    </nav>

    <!-- Copyright -->
    <p class="footer-copy">© {year} 7onic</p>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  /* Logo */
  .footer-logo {
    display: block;
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .footer-logo:hover {
    opacity: 1;
  }

  .footer-logo svg {
    display: block;
  }

  /* Nav */
  .footer-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-nav a {
    display: inline-flex;
    align-items: center;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--color-text);
  }

  .footer-dot {
    color: var(--color-border);
    font-size: 0.75rem;
    user-select: none;
  }

  /* Copyright */
  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.6;
    margin: 0;
  }
</style>

<style is:global>
  .footer-mono-h { fill: #9CA3AF; }
  .footer-mono-d { fill: #4B5563; }
  .footer-mono-i { fill: #1F2937; }

  [data-theme="dark"] .footer-mono-h { fill: #6B7280; }
  [data-theme="dark"] .footer-mono-d { fill: #D1D5DB; }
  [data-theme="dark"] .footer-mono-i { fill: #F3F4F6; }
</style>
