---
import { getCollection } from 'astro:content';
import { CATEGORIES, SERIES } from '../consts';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categoryCounts = CATEGORIES.map((cat) => ({
  ...cat,
  count: allPosts.filter((p) => p.data.category === cat.id).length,
}));

const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <!-- Categories -->
  <div class="sidebar-section">
    <h3 class="sidebar-label">Categories</h3>
    <ul class="sidebar-list">
      <li>
        <a href="/" class={`sidebar-link${currentPath === '/' ? ' active' : ''}`}>
          <span>All Posts</span>
          <span class="sidebar-count">{allPosts.length}</span>
        </a>
      </li>
      {categoryCounts.map((cat) => (
        <li>
          <a
            href={`/category/${cat.id}`}
            class={`sidebar-link${currentPath.includes(`/category/${cat.id}`) ? ' active' : ''}`}
          >
            <span>{cat.label}</span>
            {cat.count > 0 && <span class="sidebar-count">{cat.count}</span>}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Series -->
  {SERIES.length > 0 && (
    <div class="sidebar-section">
      <h3 class="sidebar-label">Series</h3>
      <ul class="sidebar-list">
        {SERIES.map((s) => {
          const count = allPosts.filter((p) => p.data.series === s.id).length;
          return (
            <li>
              <a href="/" class="sidebar-link">
                <span>{s.label}</span>
                {count > 0 && <span class="sidebar-count">{count}</span>}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  )}
</aside>

<style>
  .sidebar {
    width: 200px;
    flex-shrink: 0;
    /* Left sidebar via CSS order */
    order: -1;
    /* Sticky: header(56px) + breathing room */
    position: sticky;
    top: calc(56px + 1.5rem);
    padding-top: 2.5rem;
    /* Prevent sidebar from growing beyond viewport */
    align-self: flex-start;
    max-height: calc(100vh - 56px - 3rem);
    overflow-y: auto;
  }

  .sidebar-section {
    margin-bottom: 2rem;
  }

  .sidebar-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.625rem;
  }

  .sidebar-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3125rem 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: 5px;
    transition: color 0.15s, background-color 0.15s;
  }

  .sidebar-link:hover {
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
  }

  .sidebar-link.active {
    color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 8%, transparent);
    font-weight: 500;
  }

  .sidebar-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    padding: 0.0625rem 0.375rem;
    border-radius: 999px;
    min-width: 20px;
    text-align: center;
  }

  .sidebar-link.active .sidebar-count {
    background-color: color-mix(in srgb, #7c3aed 15%, transparent);
    color: #7c3aed;
  }

  /* Hide on mobile — use hamburger menu instead */
  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }
  }
</style>
