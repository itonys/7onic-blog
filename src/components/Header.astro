---
import { SITE_TITLE, DOCS_URL } from '../consts';
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-dot" aria-hidden="true"></span>
      {SITE_TITLE}
    </a>

    <nav class="nav" aria-label="Main navigation">
      <a href="/blog">Blog</a>
      <a href="/about">About</a>
      <a href={DOCS_URL} target="_blank" rel="noopener noreferrer" class="docs-link">
        Docs
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M3.5 2H2a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V8.5M7 1h4m0 0v4m0-4L5.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>

    <div class="social-links">
      <a href="https://github.com/itonys/7onic" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
      <a href="https://x.com/7onic_design" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
        <svg width="18" height="18" viewBox="0 0 1200 1227" fill="currentColor" aria-hidden="true">
          <path d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
    backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #7c3aed;
    flex-shrink: 0;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .nav a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 0.375rem 0.625rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .nav a:hover {
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
  }

  .docs-link {
    color: var(--color-text-muted);
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--color-text-muted);
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
    text-decoration: none;
  }

  .social-links a:hover {
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
  }

  @media (max-width: 480px) {
    .social-links {
      display: none;
    }
  }
</style>
