---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Sidebar from '../../components/Sidebar.astro';
import { SERIES, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  return SERIES.map((s) => ({
    params: { id: s.id },
    props: {
      series: s,
      posts: allPosts
        .filter((p) => p.data.series === s.id)
        .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0)),
    },
  }));
}

const { series, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${series.label} — ${SITE_TITLE}`}
      description={series.description}
    />
  </head>
  <body>
    <Header />
    <div class="page-wrapper">
      <main class="main-content">

        <div class="page-header">
          <a href="/" class="back-link">← All Posts</a>
          <div class="series-label">Series</div>
          <div class="title-row">
            <h1 class="page-title">{series.label}</h1>
            <span class="page-count">{posts.length} article{posts.length !== 1 ? 's' : ''}</span>
          </div>
          {series.description && (
            <p class="series-desc">{series.description}</p>
          )}
        </div>

        {posts.length === 0 ? (
          <p class="empty">No posts in this series yet.</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li class="post-item">
                <a href={`/${post.id}/`} class="post-link">
                  <div class="post-meta">
                    {post.data.seriesOrder && (
                      <span class="post-order">#{post.data.seriesOrder}</span>
                    )}
                    <span class="post-date">
                      <FormattedDate date={post.data.pubDate} />
                    </span>
                  </div>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="post-desc">{post.data.description}</p>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )}

      </main>
      <Sidebar />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .main-content {
    flex: 1;
    min-width: 0;
  }

  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .series-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
    margin-bottom: 0.375rem;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
  }

  .page-title {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }

  .page-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .series-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0.625rem 0 0;
    line-height: 1.6;
  }

  .empty {
    padding-top: 3rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.25rem 0;
    text-decoration: none;
  }

  .post-link:hover .post-title {
    color: #7c3aed;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
  }

  .post-order {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #7c3aed;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.3rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .page-wrapper {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
