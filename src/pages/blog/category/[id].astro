---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { CATEGORIES, SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  return CATEGORIES.map((cat) => ({
    params: { id: cat.id },
    props: {
      category: cat,
      posts: allPosts
        .filter((p) => p.data.category === cat.id)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${category.label} — ${SITE_TITLE}`}
      description={`All posts in ${category.label}`}
    />
  </head>
  <body>
    <Header />
    <main class="main">

      <div class="page-header">
        <a href="/blog" class="back-link">← All Posts</a>
        <h1 class="page-title">{category.label}</h1>
        <p class="page-count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
      </div>

      <!-- Category filter -->
      <div class="filter-row">
        <a href="/blog" class="filter-pill">All</a>
        {CATEGORIES.map((cat) => (
          <a
            href={`/blog/category/${cat.id}`}
            class={`filter-pill${cat.id === category.id ? ' active' : ''}`}
          >
            {cat.label}
          </a>
        ))}
      </div>

      {posts.length === 0 ? (
        <p class="empty">No posts in this category yet.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`} class="post-link">
                <div class="post-meta">
                  <span class="post-category">{category.label}</span>
                  <span class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </span>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                {post.data.description && (
                  <p class="post-desc">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}

    </main>
    <Footer />
  </body>
</html>

<style>
  .main {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-header {
    padding: 3rem 0 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 0.25rem;
  }

  .page-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.3125rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }

  .filter-pill:hover,
  .filter-pill.active {
    color: #7c3aed;
    border-color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 8%, transparent);
  }

  .empty {
    padding-top: 3rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-top: 1px solid var(--color-border);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
  }

  .post-link:hover .post-title {
    color: #7c3aed;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-category {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.375rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
