---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} ogImage={new URL('/og/site/home.png', Astro.site).toString()} />
  </head>
  <body>
    <Header />
    <div class="page-wrapper">
      <main class="main-content">

        <!-- Hero -->
        <section class="hero page-top">
          <div class="hero-badge">Design to Code</div>
          <h1 class="hero-title">
            A designer building<br />a design system.
          </h1>
          <p class="hero-desc">{SITE_DESCRIPTION}</p>
        </section>

        <!-- Featured Series -->
        <section class="series-section">
          <a href="/series/design-to-code" class="series-card">
            <div class="series-meta">
              <span class="series-label">Featured Series</span>
            </div>
            <h2 class="series-title">Design to Code</h2>
            <p class="series-desc">A designer's journey building a design system — from Figma tokens to production components, Tailwind, AI tooling, and CLI.</p>
            <span class="series-cta">Read the series →</span>
          </a>
        </section>

        <!-- Category pills -->
        <section class="categories-section">
          <div class="categories">
            {CATEGORIES.map((cat) => (
              <a href={`/category/${cat.id}`} class="category-pill">
                {cat.label}
              </a>
            ))}
          </div>
        </section>

        <!-- Recent Posts -->
        <section class="posts-section">
          <h2 class="section-label">Recent Posts</h2>

          {posts.length === 0 ? (
            <p class="empty">No posts yet. First one coming soon.</p>
          ) : (
            <ul class="post-list">
              {posts.map((post) => {
                const cat = CATEGORIES.find((c) => c.id === post.data.category);
                return (
                  <li class="post-item">
                    <a href={`/${post.id}/`} class="post-link">
                      <div class="post-meta">
                        {cat && <span class="post-category">{cat.label}</span>}
                        <span class="post-date">
                          <FormattedDate date={post.data.pubDate} />
                        </span>
                      </div>
                      <h3 class="post-title">{post.data.title}</h3>
                      {post.data.description && (
                        <p class="post-desc">{post.data.description}</p>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          )}

        </section>

      </main>
      <Sidebar />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .main-content {
    flex: 1;
    min-width: 0;
  }

  /* Hero */
  .hero {
    padding-bottom: 2rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 10%, transparent);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 520px;
    margin: 0;
  }

  /* Featured Series */
  .series-section {
    padding: 0 0 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .series-card {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background-color: var(--color-bg-subtle);
    text-decoration: none;
    transition: border-color 0.15s, background-color 0.15s;
  }

  .series-card:hover {
    border-color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 4%, var(--color-bg-subtle));
  }

  .series-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .series-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
  }

.series-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }

  .series-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .series-cta {
    font-size: 0.875rem;
    font-weight: 500;
    color: #7c3aed;
  }

  /* Category pills */
  .categories-section {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-pill {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.3125rem 0.875rem;
    border-radius: 999px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }

  .category-pill:hover {
    color: #7c3aed;
    border-color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 8%, transparent);
  }

  /* Posts */
  .posts-section {
    padding-top: 2.5rem;
  }

  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  .empty {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    border-top: 1px solid var(--color-border);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.25rem 0;
    text-decoration: none;
  }

  .post-link:hover .post-title {
    color: #7c3aed;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.375rem;
  }

  .post-category {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.3rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .all-posts-link {
    display: inline-block;
    margin-top: 1.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #7c3aed;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .all-posts-link:hover {
    opacity: 0.75;
  }

  /* Sidebar responsive */
  @media (max-width: 768px) {
    .page-wrapper {
      flex-direction: column;
      gap: 0;
      padding: 0 1rem;
    }
  }
</style>
