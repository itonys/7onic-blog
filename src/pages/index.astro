---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="main">

      <!-- Hero -->
      <section class="hero">
        <div class="hero-badge">Design to Code</div>
        <h1 class="hero-title">
          A designer building<br />a design system.
        </h1>
        <p class="hero-desc">{SITE_DESCRIPTION}</p>
      </section>

      <!-- Categories -->
      <section class="categories-section">
        <div class="categories">
          {CATEGORIES.map((cat) => (
            <a href={`/blog/category/${cat.id}`} class="category-pill">
              {cat.label}
            </a>
          ))}
        </div>
      </section>

      <!-- Recent Posts -->
      <section class="posts-section">
        <h2 class="section-title">Recent Posts</h2>

        {posts.length === 0 ? (
          <p class="empty">No posts yet. First one coming soon.</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => {
              const cat = CATEGORIES.find((c) => c.id === post.data.category);
              return (
                <li class="post-item">
                  <a href={`/blog/${post.id}/`} class="post-link">
                    <div class="post-meta">
                      {cat && <span class="post-category">{cat.label}</span>}
                      <span class="post-date">
                        <FormattedDate date={post.data.pubDate} />
                      </span>
                    </div>
                    <h3 class="post-title">{post.data.title}</h3>
                    {post.data.description && (
                      <p class="post-desc">{post.data.description}</p>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        )}

        <a href="/blog" class="all-posts-link">All posts →</a>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  .main {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 10%, transparent);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 560px;
    margin: 0;
  }

  /* Categories */
  .categories-section {
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-pill {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.3125rem 0.875rem;
    border-radius: 999px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
  }

  .category-pill:hover {
    color: #7c3aed;
    border-color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 8%, transparent);
  }

  /* Posts */
  .posts-section {
    padding-top: 3rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  .empty {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    border-top: 1px solid var(--color-border);
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .post-link:hover .post-title {
    color: #7c3aed;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-category {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #7c3aed;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.375rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .all-posts-link {
    display: inline-block;
    margin-top: 2rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #7c3aed;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .all-posts-link:hover {
    opacity: 0.75;
  }
</style>
