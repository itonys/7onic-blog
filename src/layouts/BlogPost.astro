---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_URL, AUTHOR_NAME, CATEGORIES, SERIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { id: string };

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  series,
  seriesOrder,
} = Astro.props;

const ogImageUrl = new URL(`/og/${id}.png`, Astro.site).toString();
const canonicalUrl = new URL(`/blog/${id}/`, Astro.site).toString();

const categoryLabel = CATEGORIES.find((c) => c.id === category)?.label ?? category;
const seriesLabel = series
  ? SERIES.find((s) => s.id === series)?.label
  : undefined;

// JSON-LD: BlogPosting
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImageUrl,
  url: canonicalUrl,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: '7onic',
    url: SITE_URL,
  },
  keywords: tags.join(', '),
  articleSection: categoryLabel,
};
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImageUrl}
      canonicalUrl={canonicalUrl}
    />
    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-[var(--color-bg)] text-[var(--color-text)]">
    <Header />
    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
      <article>
        <!-- Post header -->
        <header class="mb-10">
          <!-- Category + series -->
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-brand)] bg-[var(--color-brand-light)] dark:bg-[var(--color-brand-light-dark)] px-3 py-1 rounded-full">
              {categoryLabel}
            </span>
            {seriesLabel && seriesOrder && (
              <span class="text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-subtle)] px-3 py-1 rounded-full">
                {seriesLabel} #{seriesOrder}
              </span>
            )}
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4 text-[var(--color-text)]">
            {title}
          </h1>

          <p class="text-lg text-[var(--color-text-muted)] mb-6">{description}</p>

          <!-- Date -->
          <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
            <FormattedDate date={pubDate} />
            {updatedDate && updatedDate.toISOString() !== pubDate.toISOString() && (
              <span>· Updated <FormattedDate date={updatedDate} /></span>
            )}
          </div>

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {tags.map((tag: string) => (
                <span class="text-xs text-[var(--color-text-muted)] bg-[var(--color-bg-subtle)] border border-[var(--color-border)] px-2.5 py-1 rounded-full">
                  #{tag}
                </span>
              ))}
            </div>
          )}

          <hr class="mt-8 border-[var(--color-border)]" />
        </header>

        <!-- Post content -->
        <div class="prose">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
