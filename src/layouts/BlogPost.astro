---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_URL, AUTHOR_NAME, CATEGORIES, SERIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { id: string };

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  series,
  seriesOrder,
} = Astro.props;

const ogImageUrl = new URL(`/og/${id}.png`, Astro.site).toString();
const canonicalUrl = new URL(`/${id}/`, Astro.site).toString();

const categoryLabel = CATEGORIES.find((c) => c.id === category)?.label ?? category;
const seriesLabel = series
  ? SERIES.find((s) => s.id === series)?.label
  : undefined;

// Prev / Next navigation
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

let prevPost: CollectionEntry<'blog'> | null = null;
let nextPost: CollectionEntry<'blog'> | null = null;
let navContext: 'series' | 'date' = 'date';

if (series && seriesOrder) {
  // Series posts: navigate within the series
  const seriesPosts = allPosts
    .filter((p) => p.data.series === series)
    .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
  const idx = seriesPosts.findIndex((p) => p.id === id);
  if (idx > 0) prevPost = seriesPosts[idx - 1];
  if (idx < seriesPosts.length - 1) nextPost = seriesPosts[idx + 1];
  if (prevPost || nextPost) navContext = 'series';
}

// Non-series or alone in series → date-based navigation
if (!prevPost && !nextPost) {
  const sorted = allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const idx = sorted.findIndex((p) => p.id === id);
  if (idx < sorted.length - 1) prevPost = sorted[idx + 1];
  if (idx > 0) nextPost = sorted[idx - 1];
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImageUrl,
  url: canonicalUrl,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: '7onic',
    url: SITE_URL,
  },
  keywords: tags.join(', '),
  articleSection: categoryLabel,
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImageUrl}
      canonicalUrl={canonicalUrl}
      ogType="article"
      keywords={tags}
    />
    <!-- Article-specific Open Graph -->
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:modified_time" content={(updatedDate ?? pubDate).toISOString()} />
    <meta property="article:author" content={AUTHOR_NAME} />
    {category && <meta property="article:section" content={categoryLabel} />}
    {tags.map((tag: string) => <meta property="article:tag" content={tag} />)}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <Header />
    <div class="page-wrapper">
      <main class="main-content page-top">
        <article>
          <!-- Post header -->
          <header class="post-header">
            <a href="/" class="back-link">← All Posts</a>

            <div class="post-badges">
              {category && (
                <a href={`/category/${category}`} class="category-badge">
                  {categoryLabel}
                </a>
              )}
              {seriesLabel && seriesOrder && (
                <span class="series-badge">
                  {seriesLabel} #{seriesOrder}
                </span>
              )}
            </div>

            <h1 class="post-title">{title}</h1>
            <p class="post-desc">{description}</p>

            <div class="post-meta">
              <FormattedDate date={pubDate} />
              {updatedDate && updatedDate.toISOString() !== pubDate.toISOString() && (
                <span class="post-updated">· Updated <FormattedDate date={updatedDate} /></span>
              )}
            </div>

            {tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag: string) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            )}
          </header>

          <hr class="divider" />

          <!-- Post content -->
          <div class="prose">
            <slot />
          </div>
        </article>

        {/* Post navigation */}
        {(prevPost || nextPost) && (
          <nav class="post-nav" aria-label="Post navigation">
            {prevPost ? (
              <a href={`/${prevPost.id}/`} class="post-nav-link prev">
                <span class="post-nav-label">← Prev</span>
                <span class="post-nav-title">{prevPost.data.title}</span>
              </a>
            ) : <div />}
            {nextPost ? (
              <a href={`/${nextPost.id}/`} class="post-nav-link next">
                <span class="post-nav-label">Next →</span>
                <span class="post-nav-title">{nextPost.data.title}</span>
              </a>
            ) : <div />}
          </nav>
        )}

      </main>
      <Sidebar />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    min-height: 60vh;
    padding-bottom: 4rem;
  }

  /* Post header */
  .post-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .post-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .category-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 10%, transparent);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .category-badge:hover {
    opacity: 0.8;
  }

  .series-badge {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
  }

  .post-title {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 0.875rem;
  }

  .post-desc {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-updated {
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 1rem;
  }

  .tag {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.1875rem 0.625rem;
    border-radius: 999px;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  /* Post navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 3rem;
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    min-width: 0;
    min-height: 4.5rem;
    background-color: var(--color-bg-subtle);
    border: 1px solid transparent;
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s, background-color 0.15s;
  }

  .post-nav-link:hover {
    border-color: var(--color-border);
  }

  .post-nav-link.next {
    text-align: right;
  }

  .post-nav-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .post-nav-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.4;
    transition: color 0.15s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-nav-link:hover .post-nav-title {
    color: #7c3aed;
  }

  @media (max-width: 768px) {
    .page-wrapper {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0 1rem;
    }

    .main-content {
      padding-bottom: 3rem;
    }

    .post-nav {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .post-nav-link.next {
      text-align: left;
    }
  }
</style>
