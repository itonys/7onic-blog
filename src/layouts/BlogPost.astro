---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_URL, AUTHOR_NAME, CATEGORIES, SERIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { id: string };

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  series,
  seriesOrder,
} = Astro.props;

const ogImageUrl = new URL(`/og/${id}.png`, Astro.site).toString();
const canonicalUrl = new URL(`/blog/${id}/`, Astro.site).toString();

const categoryLabel = CATEGORIES.find((c) => c.id === category)?.label ?? category;
const seriesLabel = series
  ? SERIES.find((s) => s.id === series)?.label
  : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImageUrl,
  url: canonicalUrl,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: AUTHOR_NAME,
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    name: '7onic',
    url: SITE_URL,
  },
  keywords: tags.join(', '),
  articleSection: categoryLabel,
};
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImageUrl}
      canonicalUrl={canonicalUrl}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <Header />
    <div class="page-wrapper">
      <main class="main-content">
        <article>
          <!-- Post header -->
          <header class="post-header">
            <a href="/blog" class="back-link">← All Posts</a>

            <div class="post-badges">
              <a href={`/blog/category/${category}`} class="category-badge">
                {categoryLabel}
              </a>
              {seriesLabel && seriesOrder && (
                <span class="series-badge">
                  {seriesLabel} #{seriesOrder}
                </span>
              )}
            </div>

            <h1 class="post-title">{title}</h1>
            <p class="post-desc">{description}</p>

            <div class="post-meta">
              <FormattedDate date={pubDate} />
              {updatedDate && updatedDate.toISOString() !== pubDate.toISOString() && (
                <span class="post-updated">· Updated <FormattedDate date={updatedDate} /></span>
              )}
            </div>

            {tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag: string) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            )}
          </header>

          <hr class="divider" />

          <!-- Post content -->
          <div class="prose">
            <slot />
          </div>
        </article>
      </main>
      <Sidebar />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    min-height: 60vh;
    padding: 3rem 0 4rem;
  }

  /* Post header */
  .post-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .post-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .category-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #7c3aed;
    background-color: color-mix(in srgb, #7c3aed 10%, transparent);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .category-badge:hover {
    opacity: 0.8;
  }

  .series-badge {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
  }

  .post-title {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 0.875rem;
  }

  .post-desc {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .post-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-updated {
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 1rem;
  }

  .tag {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 0.1875rem 0.625rem;
    border-radius: 999px;
  }

  /* Optimal reading width ~70 chars */
  .prose {
    max-width: 680px;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  @media (max-width: 768px) {
    .page-wrapper {
      flex-direction: column;
      gap: 0;
    }

    .main-content {
      padding: 2rem 0 3rem;
    }
  }
</style>
